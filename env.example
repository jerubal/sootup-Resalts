# ─── Backend Environment Variables ───────────────────────────────────────────
# Copy this file to .env (or set system env vars) before running the backend.

# Port Spring Boot listens on (default: 8080)
PORT=8080

# CORS: Comma-separated list of frontend origins allowed to call the API.
# Add your production frontend URL here when deploying.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# ─── Frontend Environment Variables (.env in frontend/) ──────────────────────
# Copy frontend/.env.example to frontend/.env and set:
#
#   VITE_API_URL=http://localhost:8080   (backend URL the Vite proxy forwards to)
#   VITE_PORT=5173                       (port Vite dev server listens on)

# ─── FR-J: Natural-Language Query Bridge (LLM) ───────────────────────────────
# Optional. If set, the REPL can accept plain-English queries and translate
# them to DSL via the Gemini API. Omitting it falls back to heuristic matching.
#
#   LLM_API_KEY=AIza...
#   LLM_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent
#
# Map to Spring Boot properties in application.properties:
#   llm.api.key=${LLM_API_KEY:}
#   llm.api.url=${LLM_API_URL:https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent}

# ─── Running Instructions ─────────────────────────────────────────────────────
#
# Backend (Spring Boot JAR):
#   set PORT=8080
#   set CORS_ALLOWED_ORIGINS=http://localhost:5173
#   java -jar target/sootup-platform-1.0.0.jar
#
# Frontend (Vite Dev):
#   cd frontend
#   copy .env.example .env   (then edit as needed)
#   npm run dev
#
# Production Frontend Build:
#   cd frontend
#   npm run build
#   (serve dist/ from any static host or Spring Boot's static resources)
